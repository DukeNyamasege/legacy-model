# ============================================================
# .env.vps.example — copy to .env and fill in on your VPS
# ============================================================

# --- Docker / PostgreSQL ---
POSTGRES_DB=deriv_bot
POSTGRES_USER=deriv
POSTGRES_PASSWORD=CHANGE_ME
PORT=8080

# --- Deriv API connection ---
DERIV_APP_ID=33MmAtDICSKcC7LAZj7JO
# Set this same rate under developers.deriv.com -> Dashboard -> Registered Apps.
# The worker uses the registered App ID and authenticated direct-buy transport
# when markup is enabled; public proposals and bulk payloads remain markup-free.
DERIV_APP_MARKUP_PERCENTAGE=3.0
DERIV_ENVIRONMENT=demo
DERIV_PUBLIC_WS_URL=wss://api.derivws.com/trading/v1/options/ws/public
DERIV_REST_BASE_URL=https://api.derivws.com
DERIV_TRADING_ENABLED=true

# --- Deriv OAuth 2.0 (PKCE) ---
DERIV_OAUTH_CLIENT_ID=33MmAtDICSKcC7LAZj7JO
DERIV_OAUTH_REDIRECT_URL=https://derivadmin.site/oauth/callback

# --- Token encryption ---
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DERIV_TOKEN_ENCRYPTION_KEY=GENERATE_ON_VPS

# --- Trading safety locks ---
# Demo accounts can run with these demo-safe values.
# To let linked real accounts execute too, set TRADING_MODE=real and
# ALLOW_REAL_TRADING=true in the real VPS .env after you are ready.
TRADING_MODE=demo
ALLOW_REAL_TRADING=false
PRODUCTION_ACKNOWLEDGEMENT=

# --- Dashboard / API control ---
# Set a strong random string here. Required for dashboard control actions.
CONTROL_API_KEY=CHANGE_ME

# --- Session secret ---
SESSION_SECRET=GENERATE_ON_VPS

# --- Frontend CORS ---
# Comma-separated list of allowed frontend origins.
FRONTEND_ORIGINS=https://derivadmin.site
TRUSTED_HOSTS=derivadmin.site,www.derivadmin.site,localhost,127.0.0.1,::1,api

# --- Session cookie domain ---
# Set to the public site domain so the session cookie is scoped correctly.
CLIENT_SESSION_COOKIE_DOMAIN=derivadmin.site

# --- Model run ID ---
RF_STRATEGY_RUN_ID=rfdir5v1

# --- Copy trading ---
# Strongly recommended. Recent Contracts uses this account for signed-out viewers.
# Use the full account ID, for example DOT12345678 (never an API token).
COPYTRADING_MASTER_ACCOUNT_ID=
COPYTRADING_INCLUDE_MASTER=true
RF_MARKET_SYMBOLS=R_10,R_100,R_75,1HZ10V,1HZ75V
REQUIRE_RISING_TICKS=true
RISING_POLICY=high_frequency_momentum
BAYESIAN_MIN_EDGE_CONFIDENCE=0.50

# --- Virtual loss protection ---
# After two settled actual losses, that account switches to $0-impact virtual
# observations until the first virtual win, then the next real/demo entry uses
# the existing recovery stake calculation.
VIRTUAL_PROTECTION_ENABLED=true
VIRTUAL_TRIGGER_ACTUAL_LOSSES=2
VIRTUAL_EXIT_AFTER_WINS=1
VIRTUAL_MAX_OBSERVATIONS=0
VIRTUAL_MODE_SCOPE=PER_ACCOUNT

# Emit every market tick as an immediately flushed Docker log line.
LIVE_TICK_LOG_LINES=true

# --- Hourly Telegram reports ---
# Create a bot with BotFather and add it as a channel administrator. The channel
# ID is discovered automatically; TELEGRAM_CHAT_ID is an optional override.
TELEGRAM_ALERTS_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_INTERVAL_SECONDS=3600
TELEGRAM_DASHBOARD_SCREENSHOT_ENABLED=true
TELEGRAM_DASHBOARD_URL=http://api:8080/

