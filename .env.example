# Deriv API Bot Configuration Environment Variables
# Copy this file to .env and fill in your values.

# Deriv Application ID (register one at developers.deriv.com)
DERIV_APP_ID=33MmAtDICSKcC7LAZj7JO

# Global bot account token. This powers public balance stats before login and worker trading.
DERIV_TOKEN=your_trade_scope_pat
# Optional comma-separated PATs for multiple copier accounts.
DERIV_TOKENS=

# Account mode environment: 'demo' or 'real'
DERIV_ENVIRONMENT=demo

# Base URLs (default values provided)
DERIV_PUBLIC_WS_URL=wss://api.derivws.com/trading/v1/options/ws/public
DERIV_REST_BASE_URL=https://api.derivws.com

# Safety flag: Set to false to dry-run (logs signals but does not send REST bulk-purchase)
DERIV_TRADING_ENABLED=true
TRADING_MODE=demo
ALLOW_REAL_TRADING=false
PRODUCTION_ACKNOWLEDGEMENT=
TEST_RUN_ID=bin22001

# PostgreSQL is required for deployed environments. SQLite is available for local testing.
DATABASE_URL=sqlite:///data/bin22001.db
CONTROL_API_KEY=replace-with-a-long-random-value
FRONTEND_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,https://derivadmin.site
FRONTEND_ORIGIN_REGEX=
DEPLOYMENT_ID=local
PORT=8080

# Optional Netlify mirror sync for the public dashboard.
# Example:
# NETLIFY_SYNC_URL=https://your-site.netlify.app/.netlify/functions/sync-ingest
# NETLIFY_SYNC_TOKEN=choose-a-long-random-secret
# NETLIFY_SYNC_INTERVAL_SECONDS=15
NETLIFY_SYNC_URL=
NETLIFY_SYNC_TOKEN=
NETLIFY_SYNC_INTERVAL_SECONDS=15

# OAuth 2.0 config
DERIV_OAUTH_CLIENT_ID=33MmAtDICSKcC7LAZj7JO
DERIV_OAUTH_REDIRECT_URL=https://derivadmin.site/oauth/callback

# Optional: Token encryption key (32-byte url-safe base64 key for cryptography.fernet)
# Generate one using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DERIV_TOKEN_ENCRYPTION_KEY=

# Render backend URL (Used by Netlify functions for OAuth Proxying and UI config)
# Example: https://legacy-model.onrender.com
# Netlify Functions use this to proxy server-side requests to Render.
API_BASE_URL=https://legacy-model.onrender.com

# Optional browser API override. Leave blank for derivadmin.site so cookies stay same-origin.
DASHBOARD_API_BASE_URL=
