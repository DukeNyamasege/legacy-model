# Deriv API Bot Configuration Environment Variables
# Copy this file to .env and fill in your values.

# Deriv Application ID (register one at developers.deriv.com)
DERIV_APP_ID=your_new_deriv_app_id
DERIV_TOKEN=your_trade_scope_pat
# Optional comma-separated PATs for multiple copier accounts.
DERIV_TOKENS=

# Account mode environment: 'demo' or 'real'
DERIV_ENVIRONMENT=demo

# Base URLs (default values provided)
DERIV_PUBLIC_WS_URL=wss://api.derivws.com/trading/v1/options/ws/public
DERIV_REST_BASE_URL=https://api.derivws.com

# Safety flag: Set to false to dry-run (logs signals but does not send REST bulk-purchase)
DERIV_TRADING_ENABLED=true
TRADING_MODE=demo
ALLOW_REAL_TRADING=false
PRODUCTION_ACKNOWLEDGEMENT=
TEST_RUN_ID=bin22001

# PostgreSQL is required for deployed environments. SQLite is available for local testing.
DATABASE_URL=sqlite:///data/bin22001.db
CONTROL_API_KEY=replace-with-a-long-random-value
FRONTEND_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
FRONTEND_ORIGIN_REGEX=
DEPLOYMENT_ID=local
PORT=8080

# OAuth 2.0 config (optional, only used for OAuth user login flow helper)
DERIV_OAUTH_CLIENT_ID=
DERIV_OAUTH_REDIRECT_URL=https://localhost/oauth/callback

# Optional: Token encryption key (32-byte url-safe base64 key for cryptography.fernet)
# Generate one using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DERIV_TOKEN_ENCRYPTION_KEY=
